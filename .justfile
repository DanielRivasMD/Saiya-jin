####################################################################################################

_default:
  @just --choose

####################################################################################################

@show:
  bat .justfile --language make

####################################################################################################

@edit:
  micro .justfile

####################################################################################################

karabiner := `echo $HOME/.saiyajin/karabiner`

@link:
  ln -svf "{{karabiner}}" "$HOME/.config/"
  ln -svf "{{karabiner}}/karabiner.edn" "$HOME/.config/"

####################################################################################################
